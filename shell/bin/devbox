#!/bin/bash

LOCAL_IP="10.10.3.33"
TAILNET_IP="100.79.76.40"

# Resolve which IP to use by checking the routing table.
# If the route to the local IP goes through a tailscale interface, we're
# off-network and should use the tailnet IP instead.
_devbox_ip() {
    local dev
    dev=$(ip route get "$LOCAL_IP" 2>/dev/null | awk 'NR==1 { for (i=1;i<=NF;i++) if ($i=="dev") print $(i+1) }')
    if [[ -z "$dev" || "$dev" == tailscale* ]]; then
        echo "$TAILNET_IP"
    else
        echo "$LOCAL_IP"
    fi
}

TARGET=$(_devbox_ip)
echo "Connecting to devbox ($TARGET)..."
exec ssh "$TARGET" "$@"
