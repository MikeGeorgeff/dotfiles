#!/bin/bash

LOCAL_IP="10.10.3.33"
TAILNET_IP="100.79.76.40"
BEACON_URL="http://10.10.3.99/"
BEACON_UUID="1117418b-566e-4d9c-9008-652f6d971d7b"

_devbox_ip() {
    local response
    response=$(curl -sf --max-time 2 "$BEACON_URL" 2>/dev/null | tr -d '[:space:]')
    if [[ "$response" == "$BEACON_UUID" ]]; then
        echo "$LOCAL_IP"
    else
        echo "$TAILNET_IP"
    fi
}

TARGET=$(_devbox_ip)

# Abort if we would SSH into ourselves
if ip addr show 2>/dev/null | grep -qF "inet $TARGET/"; then
    echo "Already on devbox ($TARGET), aborting." >&2
    exit 1
fi

echo "Connecting to devbox ($TARGET)..."
exec ssh "$TARGET" "$@"
